{
  "name": "nidux/niduxrest-php",
  "description": "A modern, fluent HTTP client. Forked from Mashape, reimagined by Nidux, and open-sourced for the PHP community.",
  "keywords": [
    "http",
    "client",
    "rest",
    "api",
    "fluent",
    "nidux",
    "curl"
  ],
  "type": "library",
  "license": "MIT",
  "require": {
    "php": ">=8.3",
    "ext-curl": "*",
    "ext-json": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "autoload": {
    "psr-4": {
      "Nidux\\Rest\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Nidux\\Rest\\Tests\\": "tests/"
    }
  },
  "authors": [
    {
      "name": "Carlos Alberto Umanzor Arguedas",
      "email": "carlos@nidux.com",
      "role": "Lead Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/Nidux/NiduxRest/issues",
    "source": "https://github.com/Nidux/NiduxRest"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}